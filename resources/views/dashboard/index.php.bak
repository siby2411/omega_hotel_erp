<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>OMEGA HOTEL ERP</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:linear-gradient(135deg,#0f172a,#1e293b);
color:white;
}

.hero{
padding:40px;
border-radius:20px;
background:rgba(255,255,255,.05);
backdrop-filter:blur(10px);
}

.card{
background:#1e293b;
border:none;
border-radius:20px;
}

.btn-omega{
background:#38bdf8;
border:none;
}

</style>

</head>

<body>

<div class="container mt-4">

<div class="hero text-center mb-4">

<h1>🏨 OMEGA INFORMATIQUE CONSULTING</h1>

<p>ERP HÔTELIER PROFESSIONNEL</p>

</div>

<div class="row g-4">

<div class="col-md-3">
<div class="card p-3">
<h5>🛏 Chambres</h5>
<a href="?url=chambres" class="btn btn-omega">Liste</a>
<a href="?url=chambres_create" class="btn btn-success mt-2">Ajout</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>📅 Réservations</h5>
<a href="?url=reservations" class="btn btn-omega">Liste</a>
<a href="?url=reservations_create" class="btn btn-success mt-2">Ajout</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>👥 Clients</h5>
<a href="?url=clients" class="btn btn-omega">Liste</a>
<a href="?url=clients_create" class="btn btn-success mt-2">Ajout</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>💳 Factures</h5>
<a href="?url=factures" class="btn btn-warning">Accéder</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>💰 Paiements</h5>
<a href="?url=paiements" class="btn btn-warning">Accéder</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>👨‍💼 Personnel</h5>
<a href="?url=personnel" class="btn btn-warning">Accéder</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>🧾 Paie</h5>
<a href="?url=paie" class="btn btn-warning">Accéder</a>
</div>
</div>

<div class="col-md-3">
<div class="card p-3">
<h5>💬 Messagerie</h5>
<a href="?url=messagerie" class="btn btn-warning">Accéder</a>
</div>
</div>

</div>

</div>

</body>
</html>
